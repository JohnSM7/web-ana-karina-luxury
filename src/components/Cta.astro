---
import { salon } from '../data/salon';
---
<section class="relative py-24 lg:py-32 bg-blush overflow-hidden">
  <div class="relative mx-auto max-w-5xl px-6">
    <div class="relative rounded-[1.5rem] sm:rounded-[2.5rem] gradient-rose p-7 sm:p-10 lg:p-16 text-blush text-center overflow-hidden shadow-luxury reveal-on-scroll">
      <!-- Decorative grain -->
      <div class="absolute inset-0 grain"></div>

      <!-- Floating script word -->
      <span class="absolute top-4 right-6 font-script text-7xl lg:text-9xl text-blush/15 leading-none select-none pointer-events-none">cita</span>

      <p class="relative text-xs uppercase tracking-[0.4em] text-blush/80 mb-6">— Reserva</p>
      <h2 class="relative font-display text-balance text-[clamp(2rem,5vw,4rem)] leading-[1.05] tracking-tight">
        Tu próxima <span class="font-script text-[1.4em] italic">transformación</span>
        <br />
        empieza con un mensaje.
      </h2>

      <div class="relative mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={`https://wa.me/${salon.whatsapp}?text=Hola%20Ana%20Karina%2C%20quiero%20reservar%20una%20cita`}
          target="_blank"
          rel="noopener"
          class="btn-magnetic inline-flex items-center gap-3 rounded-full bg-blush text-rose-deep px-7 py-4 font-medium shadow-xl hover:scale-[1.02] transition-transform"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2.1-.4 0-.5L8.8 7.1c-.2-.5-.5-.4-.7-.4h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.7 1.2 2.9.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3Z"/>
            <path d="M20 4a10 10 0 0 0-15.6 12L3 21l5.1-1.3A10 10 0 1 0 20 4Zm-8 17a9 9 0 0 1-4.5-1.2l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 12 21Z"/>
          </svg>
          Escribir por WhatsApp
        </a>
        <a
          href={salon.redes.treatwell}
          target="_blank"
          rel="noopener"
          class="btn-magnetic inline-flex items-center gap-2 rounded-full bg-blush/20 backdrop-blur border border-blush/30 text-blush px-6 py-4 font-medium hover:bg-blush/30 transition-colors"
        >
          Reservar en Treatwell →
        </a>
      </div>

      <p class="relative mt-8 text-blush/70 text-xs uppercase tracking-[0.3em]">
        respondemos de Lun a Sáb · 10:00 — 19:00
      </p>
    </div>
  </div>
</section>
