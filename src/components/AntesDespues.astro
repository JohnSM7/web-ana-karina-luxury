---
import { Image } from 'astro:assets';
import antes from '../../public/images/work-botox-chocolate.jpg';
import despues from '../../public/images/work-treatment-02.jpg';
---
<section class="relative py-24 lg:py-32 bg-blush overflow-hidden">
  <div class="mx-auto max-w-7xl px-6">
    <header class="text-center max-w-3xl mx-auto mb-12 reveal-on-scroll">
      <p class="text-xs uppercase tracking-[0.4em] text-rose-deep/70 mb-4">— Antes & Después</p>
      <h2 class="font-display text-balance text-[clamp(2.25rem,4.5vw,4rem)] leading-[1.05] tracking-tight text-wine">
        Resultados que <span class="italic font-light gradient-text-luxe">hablan solos</span>
      </h2>
      <p class="mt-5 text-wine/60 text-pretty">
        Arrastra el deslizador para descubrir la transformación. Botox capilar real, hidratación y brillo desde la primera sesión.
      </p>
    </header>

    <div class="relative max-w-4xl mx-auto reveal-on-scroll">
      <!-- Decorative gold corners -->
      <div class="absolute -top-3 -left-3 w-8 h-8 border-t-2 border-l-2 border-gold rounded-tl-xl"></div>
      <div class="absolute -top-3 -right-3 w-8 h-8 border-t-2 border-r-2 border-gold rounded-tr-xl"></div>
      <div class="absolute -bottom-3 -left-3 w-8 h-8 border-b-2 border-l-2 border-gold rounded-bl-xl"></div>
      <div class="absolute -bottom-3 -right-3 w-8 h-8 border-b-2 border-r-2 border-gold rounded-br-xl"></div>

      <div
        id="ba-slider"
        class="relative aspect-[4/5] sm:aspect-[16/10] rounded-2xl sm:rounded-3xl overflow-hidden shadow-luxury cursor-ew-resize select-none touch-none"
        role="slider"
        aria-label="Comparador antes y después"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
        tabindex="0"
      >
        <!-- AFTER (background) -->
        <div class="absolute inset-0">
          <Image
            src={despues}
            alt="Después del tratamiento — cabello hidratado y con brillo"
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width:768px) 100vw, 80vw"
            loading="lazy"
          />
          <div class="absolute top-4 right-4 px-3 py-1 rounded-full bg-rose text-blush text-[11px] font-medium uppercase tracking-widest">Después</div>
        </div>

        <!-- BEFORE (clipped) -->
        <div id="ba-before" class="absolute inset-0" style="clip-path: inset(0 50% 0 0);">
          <Image
            src={antes}
            alt="Antes del tratamiento — cabello sin brillo"
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width:768px) 100vw, 80vw"
            loading="lazy"
          />
          <div class="absolute top-4 left-4 px-3 py-1 rounded-full bg-wine/80 backdrop-blur text-blush text-[11px] font-medium uppercase tracking-widest">Antes</div>
        </div>

        <!-- Drag handle -->
        <div id="ba-handle" class="absolute top-0 bottom-0 w-1 bg-blush shadow-[0_0_30px_rgba(233,30,99,0.6)]" style="left: 50%;">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full gradient-rose grid place-items-center shadow-luxury">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blush" aria-hidden="true">
              <path d="m9 18-6-6 6-6"/>
              <path d="m15 6 6 6-6 6"/>
            </svg>
          </div>
        </div>
      </div>

      <p class="text-center text-xs uppercase tracking-[0.3em] text-wine/40 mt-6">
        ← desliza para comparar →
      </p>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById('ba-slider');
  const handle = document.getElementById('ba-handle');
  const before = document.getElementById('ba-before');
  if (slider && handle && before) {
    let isDragging = false;
    const setPos = (pct: number) => {
      const clamped = Math.max(0, Math.min(100, pct));
      handle.style.left = clamped + '%';
      before.style.clipPath = `inset(0 ${100 - clamped}% 0 0)`;
      slider.setAttribute('aria-valuenow', String(Math.round(clamped)));
    };
    const onMove = (clientX: number) => {
      const r = slider.getBoundingClientRect();
      setPos(((clientX - r.left) / r.width) * 100);
    };
    slider.addEventListener('pointerdown', (e) => {
      isDragging = true;
      slider.setPointerCapture(e.pointerId);
      onMove(e.clientX);
    });
    slider.addEventListener('pointermove', (e) => {
      if (isDragging) onMove(e.clientX);
    });
    slider.addEventListener('pointerup', () => { isDragging = false; });
    slider.addEventListener('pointercancel', () => { isDragging = false; });

    // Auto-demo on viewport enter (one shot)
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            let pos = 50;
            let dir = 1;
            const start = Date.now();
            const id = setInterval(() => {
              pos += dir * 1.4;
              if (pos >= 80) dir = -1;
              if (pos <= 30) dir = 1;
              setPos(pos);
              if (Date.now() - start > 3200) {
                clearInterval(id);
                setPos(50);
              }
            }, 18);
            obs.disconnect();
          }
        }
      },
      { threshold: 0.5 }
    );
    io.observe(slider);

    // Keyboard support
    slider.addEventListener('keydown', (e) => {
      const curr = parseFloat(handle.style.left);
      if (e.key === 'ArrowLeft') setPos(curr - 5);
      if (e.key === 'ArrowRight') setPos(curr + 5);
    });
  }
</script>
