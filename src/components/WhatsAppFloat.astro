---
import { salon } from '../data/salon';
const msg = encodeURIComponent('Hola Ana Karina, me gustaría reservar una cita 💖');
const href = `https://wa.me/${salon.whatsapp}?text=${msg}`;
---
<a
  href={href}
  target="_blank"
  rel="noopener"
  aria-label="Reservar por WhatsApp"
  class="group fixed z-50 bottom-5 right-5 sm:bottom-6 sm:right-6 flex items-center gap-2"
  style="padding-bottom: env(safe-area-inset-bottom);"
  id="wa-float"
>
  <!-- Tooltip desktop -->
  <span class="hidden md:inline-flex items-center gap-1.5 rounded-full bg-blush/95 backdrop-blur-md border border-rose-soft/40 text-wine text-xs font-medium px-3.5 py-2 shadow-soft opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 pointer-events-none whitespace-nowrap">
    Reserva en 1 minuto
    <span class="text-rose">→</span>
  </span>

  <!-- Botón principal -->
  <span class="relative grid place-items-center w-14 h-14 sm:w-16 sm:h-16 rounded-full gradient-rose text-blush shadow-luxury group-hover:scale-110 transition-transform duration-300">
    <!-- Pulse halo -->
    <span class="absolute inset-0 rounded-full bg-rose opacity-60 animate-[wa-ping_2.4s_cubic-bezier(0,0,0.2,1)_infinite] -z-10"></span>
    <span class="absolute inset-0 rounded-full bg-rose-soft opacity-40 animate-[wa-ping_2.4s_cubic-bezier(0,0,0.2,1)_infinite_0.6s] -z-10"></span>

    <!-- Icono WhatsApp oficial -->
    <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sm:w-9 sm:h-9 drop-shadow-sm">
      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
    </svg>

    <!-- Badge "1" -->
    <span class="absolute -top-1 -right-1 grid place-items-center w-5 h-5 rounded-full bg-blush text-rose-deep text-[10px] font-bold border-2 border-rose shadow-md">1</span>
  </span>
</a>

<style>
  @keyframes wa-ping {
    0%   { transform: scale(1);   opacity: 0.6; }
    80%, 100% { transform: scale(2); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    #wa-float .animate-\[wa-ping_2\.4s_cubic-bezier\(0\,0\,0\.2\,1\)_infinite\],
    #wa-float .animate-\[wa-ping_2\.4s_cubic-bezier\(0\,0\,0\.2\,1\)_infinite_0\.6s\] {
      animation: none;
    }
  }
</style>

<script>
  // Oculta el botón cuando el footer está visible para no tapar el "Powered by"
  const btn = document.getElementById('wa-float');
  const footer = document.querySelector('footer');
  if (btn && footer) {
    const io = new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) {
          btn.style.opacity = '0';
          btn.style.transform = 'translateY(20px) scale(0.85)';
          btn.style.pointerEvents = 'none';
        } else {
          btn.style.opacity = '1';
          btn.style.transform = '';
          btn.style.pointerEvents = '';
        }
      },
      { threshold: 0.2 }
    );
    io.observe(footer);
    btn.style.transition = 'opacity 300ms ease, transform 300ms ease';
  }
</script>
