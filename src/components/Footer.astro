---
import { salon } from '../data/salon';
const year = new Date().getFullYear();
---
<footer class="relative bg-onyx text-pearl/80 overflow-hidden">
  <!-- Top giant script signature -->
  <div class="relative border-b border-pearl/10 py-16 overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <p class="text-xs uppercase tracking-[0.4em] text-gold mb-4">— Síguenos</p>
      <p class="font-script text-[clamp(4rem,12vw,9rem)] leading-none gradient-text-gold select-none">
        Ana Karina
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm">
        <a href={salon.redes.instagram} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-blush/5 hover:bg-rose/20 border border-pearl/10 px-4 py-2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          Instagram
        </a>
        <a href={salon.redes.tiktok} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-blush/5 hover:bg-rose/20 border border-pearl/10 px-4 py-2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.3a4.8 4.8 0 0 1-3.3-1.4 4.8 4.8 0 0 1-1.4-3.1h-3.5v13.7a2.8 2.8 0 1 1-2.8-2.8 2.8 2.8 0 0 1 .9.1V9.2a6.3 6.3 0 0 0-.9-.1 6.3 6.3 0 1 0 6.3 6.3V8.7a8.2 8.2 0 0 0 4.7 1.5V6.7a4.8 4.8 0 0 1 0-.4Z"/></svg>
          TikTok
        </a>
        <a href={salon.redes.facebook} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-blush/5 hover:bg-rose/20 border border-pearl/10 px-4 py-2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9.7 0 1.5.1 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v6.9A10 10 0 0 0 22 12Z"/></svg>
          Facebook
        </a>
        <a href={salon.redes.treatwell} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-blush/5 hover:bg-rose/20 border border-pearl/10 px-4 py-2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          Treatwell
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-6 py-12 grid gap-10 lg:grid-cols-4">
    <div>
      <div class="flex items-center gap-3">
        <span class="grid place-items-center w-10 h-10 rounded-full gradient-rose text-blush font-display italic font-bold">AK</span>
        <div class="leading-tight">
          <p class="font-display text-blush">Ana Karina</p>
          <p class="text-xs uppercase tracking-[0.2em] text-gold/70">Luxury Beauty Salon</p>
        </div>
      </div>
      <p class="mt-4 text-sm text-pearl/60 max-w-xs">
        Cuidamos tu belleza con cercanía profesional desde el corazón de Villaverde.
      </p>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-gold mb-4">Visítanos</p>
      <address class="not-italic text-sm leading-relaxed text-pearl/70">
        {salon.direccion.calle}<br/>
        {salon.direccion.cp} {salon.direccion.barrio}<br/>
        {salon.direccion.ciudad}, {salon.direccion.pais}
      </address>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-gold mb-4">Contacta</p>
      <ul class="space-y-2 text-sm text-pearl/70">
        <li><a href={`tel:${salon.telefono.replace(/\s/g, '')}`} class="hover:text-rose-soft transition-colors">{salon.telefonoDisplay}</a></li>
        <li><a href={`https://wa.me/${salon.whatsapp}`} target="_blank" rel="noopener" class="hover:text-rose-soft transition-colors">WhatsApp directo</a></li>
        <li>Atención en {salon.idiomas.join(' · ')}</li>
      </ul>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-gold mb-4">Horario</p>
      <ul class="text-sm space-y-1 text-pearl/70">
        <li class="flex justify-between"><span>Lun – Vie</span><span class="text-pearl">10:00 – 19:00</span></li>
        <li class="flex justify-between"><span>Sábado</span><span class="text-pearl">10:00 – 18:00</span></li>
        <li class="flex justify-between"><span>Domingo</span><span class="text-rose-soft/70">Cerrado</span></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-pearl/10 py-6">
    <div class="mx-auto max-w-7xl px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-pearl/40">
      <p>© {year} {salon.nombre}. Todos los derechos reservados.</p>
      <p class="flex items-center gap-1.5">
        <span>Powered by</span>
        <a
          href="https://www.tanesolutions.com/"
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-1 text-pearl/70 hover:text-rose-soft transition-colors"
          aria-label="Tane Solutions — abre en pestaña nueva"
        >
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="opacity-60 group-hover:opacity-100">
            <path d="M12 2 14.39 9.61 22 12l-7.61 2.39L12 22l-2.39-7.61L2 12l7.61-2.39L12 2Z"/>
          </svg>
          <span class="font-medium tracking-wide">Tane Solutions</span>
        </a>
      </p>
    </div>
  </div>
</footer>
