---
import { salon } from '../data/salon';
---
<nav class="fixed top-0 left-0 right-0 z-40 px-3 sm:px-6 lg:px-8 pt-3 sm:pt-4 transition-all" id="nav">
  <div class="mx-auto max-w-7xl flex items-center justify-between rounded-full bg-blush/75 backdrop-blur-xl border border-rose-soft/30 pl-3 sm:pl-4 lg:pl-6 pr-2 sm:pr-3 py-2 sm:py-2.5 shadow-soft">
    <a href="#top" class="flex items-center gap-2 group min-w-0">
      <span class="grid place-items-center w-8 sm:w-9 h-8 sm:h-9 rounded-full gradient-rose text-blush font-display italic font-bold text-base sm:text-lg shadow-md group-hover:scale-110 transition-transform shrink-0">AK</span>
      <span class="hidden sm:flex flex-col leading-none min-w-0">
        <span class="font-display italic text-wine text-sm tracking-tight truncate">Ana Karina</span>
        <span class="text-[9px] sm:text-[10px] uppercase tracking-[0.18em] sm:tracking-[0.2em] text-rose-deep/70 truncate">Luxury Beauty</span>
      </span>
    </a>

    <ul class="hidden lg:flex items-center gap-5 xl:gap-7 text-sm text-wine/80">
      <li><a href="#servicios" class="hover:text-rose transition-colors">Servicios</a></li>
      <li><a href="#galeria" class="hover:text-rose transition-colors">Galería</a></li>
      <li><a href="#precios" class="hover:text-rose transition-colors">Precios</a></li>
      <li><a href="#resenas" class="hover:text-rose transition-colors">Reseñas</a></li>
      <li><a href="#localizacion" class="hover:text-rose transition-colors">Encuéntranos</a></li>
    </ul>

    <a
      href={`https://wa.me/${salon.whatsapp}?text=Hola%20Ana%20Karina%2C%20quiero%20reservar%20una%20cita`}
      target="_blank"
      rel="noopener"
      class="btn-magnetic group relative inline-flex items-center gap-1.5 sm:gap-2 rounded-full gradient-rose text-blush text-xs sm:text-sm font-medium px-3.5 sm:px-5 py-2 sm:py-2.5 shadow-luxury hover:shadow-xl shrink-0"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sm:w-4 sm:h-4">
        <path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2.1-.4 0-.5L8.8 7.1c-.2-.5-.5-.4-.7-.4h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.7 1.2 2.9.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3Z"/>
        <path d="M20 4a10 10 0 0 0-15.6 12L3 21l5.1-1.3A10 10 0 1 0 20 4Zm-8 17a9 9 0 0 1-4.5-1.2l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 12 21Z"/>
      </svg>
      <span class="hidden sm:inline">Reservar</span>
      <span class="sm:hidden">Cita</span>
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 32) {
        nav.classList.add('scale-[0.97]');
      } else {
        nav.classList.remove('scale-[0.97]');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
