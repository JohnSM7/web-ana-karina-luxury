---
import { resenas, salon } from '../data/salon';
// duplicate for seamless marquee
const loop = [...resenas, ...resenas];
---
<section id="resenas" class="relative py-24 lg:py-32 bg-blush overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 mb-12">
    <header class="text-center max-w-3xl mx-auto reveal-on-scroll">
      <p class="text-xs uppercase tracking-[0.4em] text-rose-deep/70 mb-4">— Reseñas</p>
      <h2 class="font-display text-balance text-[clamp(2.25rem,4.5vw,4rem)] leading-[1.05] tracking-tight text-wine">
        Lo que dicen nuestras <span class="italic font-light gradient-text-luxe">clientas</span>
      </h2>
      <div class="mt-6 inline-flex items-center gap-3 text-sm">
        <div class="flex gap-0.5 text-gold">
          {Array.from({length: 5}).map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4L12 2Z"/></svg>
          ))}
        </div>
        <span class="text-wine">{salon.rating}/5</span>
        <span class="text-wine/40">·</span>
        <a href={salon.redes.google} target="_blank" rel="noopener" class="text-wine/60 underline-offset-4 hover:underline hover:text-rose">
          {salon.totalResenas}+ reseñas en Google
        </a>
      </div>
    </header>
  </div>

  <!-- Infinite marquee -->
  <div class="relative marquee-pause">
    <!-- Fade edges -->
    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-blush to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-blush to-transparent z-10 pointer-events-none"></div>

    <div class="flex gap-6 marquee w-max">
      {loop.map((r) => (
        <article class="w-[280px] sm:w-[340px] md:w-[400px] shrink-0 rounded-2xl sm:rounded-3xl border border-rose-soft/30 bg-gradient-to-br from-pearl to-blush p-5 sm:p-7 shadow-soft">
          <div class="flex gap-0.5 text-gold mb-4">
            {Array.from({length: r.rating}).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4L12 2Z"/></svg>
            ))}
          </div>
          <p class="font-display text-lg lg:text-xl text-wine leading-snug text-balance">
            <span class="text-rose font-serif text-3xl leading-none mr-1">"</span>{r.texto}<span class="text-rose font-serif text-3xl leading-none ml-1">"</span>
          </p>
          <div class="mt-6 flex items-center justify-between text-xs">
            <span class="uppercase tracking-widest text-wine/50">{r.autor}</span>
            <span class="text-rose-deep/70">{r.servicio}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
