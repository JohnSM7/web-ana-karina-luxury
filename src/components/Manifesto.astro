---
---
<section id="manifesto" class="relative py-20 sm:py-28 lg:py-48 bg-blush overflow-hidden">
  <!-- Giant transparent typography behind -->
  <div class="absolute inset-0 grid place-items-center pointer-events-none select-none -z-0 overflow-hidden">
    <span class="font-script text-[clamp(8rem,32vw,28rem)] leading-none text-rose-soft/15 -mt-4 sm:-mt-8 whitespace-nowrap" aria-hidden="true">Ana Karina</span>
  </div>

  <div class="relative mx-auto max-w-5xl px-5 sm:px-6 text-center z-10">
    <p class="text-[10px] sm:text-xs uppercase tracking-[0.35em] sm:tracking-[0.4em] text-rose-deep/70 mb-6 sm:mb-8 reveal-on-scroll">— Manifiesto</p>

    <h2 class="font-display text-balance text-[clamp(1.5rem,5vw,4rem)] leading-[1.15] sm:leading-[1.1] tracking-tight text-wine font-light italic">
      <span class="scroll-fade-up inline-block">No vendemos </span>
      <span class="scroll-fade-up inline-block gradient-text-luxe font-medium not-italic">tratamientos</span>.
      <br />
      <span class="scroll-fade-up inline-block">Creamos </span>
      <span class="scroll-fade-up inline-block font-script text-[1.4em] text-rose not-italic">momentos</span>
      <span class="scroll-fade-up inline-block"> en los que </span>
      <span class="scroll-fade-up inline-block gradient-text-gold font-medium not-italic">te reconoces</span>
      <span class="scroll-fade-up inline-block"> mejor en el espejo.</span>
    </h2>

    <div class="mt-10 sm:mt-16 grid grid-cols-2 sm:flex sm:flex-wrap justify-items-center sm:justify-center gap-6 sm:gap-8 lg:gap-16 text-wine/70 reveal-on-scroll">
      <div class="flex flex-col items-center gap-1">
        <span class="font-display text-3xl sm:text-4xl gradient-text-luxe font-bold">7</span>
        <span class="text-[10px] sm:text-xs uppercase tracking-widest">disciplinas</span>
      </div>
      <div class="hidden sm:block w-px bg-gradient-to-b from-transparent via-rose-soft to-transparent"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="font-display text-3xl sm:text-4xl gradient-text-luxe font-bold">118+</span>
        <span class="text-[10px] sm:text-xs uppercase tracking-widest">reseñas</span>
      </div>
      <div class="hidden sm:block w-px bg-gradient-to-b from-transparent via-rose-soft to-transparent"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="font-display text-3xl sm:text-4xl gradient-text-luxe font-bold">4.7★</span>
        <span class="text-[10px] sm:text-xs uppercase tracking-widest">en Google</span>
      </div>
      <div class="hidden sm:block w-px bg-gradient-to-b from-transparent via-rose-soft to-transparent"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="font-display text-3xl sm:text-4xl gradient-text-luxe font-bold">ES·中文</span>
        <span class="text-[10px] sm:text-xs uppercase tracking-widest">idiomas</span>
      </div>
    </div>
  </div>
</section>
