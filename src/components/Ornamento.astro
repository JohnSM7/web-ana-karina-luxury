---
interface Props {
  variant?: 'rose' | 'gold' | 'mono';
  bg?: string;
}
const { variant = 'gold', bg = 'bg-blush' } = Astro.props;
const color = variant === 'rose' ? '#E91E63' : variant === 'gold' ? '#D4A574' : '#1B0E14';
---
<div class={`relative ${bg} py-8 flex items-center justify-center gap-4 reveal-on-scroll`} aria-hidden="true">
  <span class="h-px w-16 sm:w-24" style={`background: linear-gradient(to right, transparent, ${color}66)`}></span>
  <svg width="36" height="36" viewBox="0 0 60 60" fill="none" stroke={color} stroke-width="1" stroke-linecap="round" class="opacity-70">
    <circle cx="30" cy="30" r="3" fill={color}/>
    <path d="M30 10 Q40 20 30 30 Q20 20 30 10 Z" />
    <path d="M30 50 Q40 40 30 30 Q20 40 30 50 Z" />
    <path d="M10 30 Q20 40 30 30 Q20 20 10 30 Z" />
    <path d="M50 30 Q40 40 30 30 Q40 20 50 30 Z" />
  </svg>
  <span class="h-px w-16 sm:w-24" style={`background: linear-gradient(to left, transparent, ${color}66)`}></span>
</div>
